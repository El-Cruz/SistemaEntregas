<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Entregas.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Entregas.MAUI.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Dashboard">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" Route="DashboardPage" />
        </Tab>

        <Tab Title="Nueva Entrega">
            <ShellContent ContentTemplate="{DataTemplate views:CrearEntregaPage}" Route="CrearEntregaPage" />
        </Tab>

        <Tab Title="Historial">
            <ShellContent ContentTemplate="{DataTemplate views:HistorialPage}" Route="HistorialPage" />
        </Tab>
    </TabBar>
</Shell>