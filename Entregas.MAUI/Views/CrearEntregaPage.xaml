<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Entregas.MAUI.ViewModels"
             x:Class="Entregas.MAUI.Views.CrearEntregaPage"
             Title="Crear Entrega"
             BackgroundColor="{StaticResource BackgroundPrimary}">

    

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <Label Text="Nueva Entrega" Style="{StaticResource HeadingMedium}"/>

            <!-- Codigo -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Codigo de referencia" Style="{StaticResource BodySmall}" TextColor="{StaticResource TextSecondary}"/>
                <Border StrokeShape="RoundRectangle 8" Padding="12" BackgroundColor="{StaticResource BackgroundSecondary}" Stroke="{StaticResource BorderBrush}">
                    <Label Text="{Binding NuevaEntrega.CodigoEntrega}" FontAttributes="Bold" FontSize="16"/>
                </Border>
            </VerticalStackLayout>

            <!-- Datos -->
            <VerticalStackLayout Spacing="16">

                <!-- INPUT ANIMADO: Destinatario -->
                <Grid Margin="0,10,0,0">
                    <Border x:Name="DestinatarioBorder" Stroke="#9e9e9e" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" BackgroundColor="Transparent" HeightRequest="56">
                        <Entry x:Name="DestinatarioEntry" 
                               Text="{Binding NuevaEntrega.Destinatario, Mode=TwoWay}" 
                               TextChanged="OnDestinatarioTextChanged"
                               Focused="Destinatario_Focused"
                               Unfocused="Destinatario_Unfocused"
                               Style="{StaticResource EntryStyle}"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>
                    <Label x:Name="DestinatarioLabel" 
                           Text="Nombre del local" 
                           InputTransparent="True" 
                           BackgroundColor="{StaticResource BackgroundPrimary}" 
                           TextColor="#e8e8e8" 
                           HorizontalOptions="Start" 
                           VerticalOptions="Center" 
                           Margin="16,0" 
                           Padding="4,0" />
                </Grid>

                <CollectionView ItemsSource="{Binding AutocompleteSuggestions}" BackgroundColor="Transparent" SelectionMode="Single">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding .}" Padding="12,8" FontSize="13">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSuggestionCommand}" CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- INPUT ANIMADO: Dirección -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8" Margin="0,10,0,0">
                    <Grid Grid.Column="0">
                        <Border x:Name="DireccionBorder" Stroke="#9e9e9e" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" BackgroundColor="Transparent" HeightRequest="56">
                            <Entry x:Name="DireccionEntry"
                                   Text="{Binding NuevaEntrega.Direccion}" 
                                   Focused="Direccion_Focused"
                                   Unfocused="Direccion_Unfocused"
                                   Style="{StaticResource EntryStyle}"
                                   BackgroundColor="Transparent"
                                   Margin="12,0"/>
                        </Border>
                        <Label x:Name="DireccionLabel" 
                               Text="Buscar dirección..." 
                               InputTransparent="True" 
                               BackgroundColor="{StaticResource BackgroundPrimary}" 
                               TextColor="#e8e8e8" 
                               HorizontalOptions="Start" 
                               VerticalOptions="Center" 
                               Margin="16,0" 
                               Padding="4,0" />
                    </Grid>
                    <Button Grid.Column="1" Text="Buscar" Command="{Binding BuscarCoordenadasCommand}" CommandParameter="{Binding Source={x:Reference DireccionEntry}, Path=Text}" Style="{StaticResource ButtonOutline}"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Productos -->
            <VerticalStackLayout Spacing="12">

                <!-- SECCION AGREGAR PRODUCTO -->
                <Border StrokeShape="RoundRectangle 8" Padding="12" BackgroundColor="{StaticResource BackgroundSecondary}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Agregar producto" FontAttributes="Bold" FontSize="14"/>
                        <Grid ColumnDefinitions="*, 90" RowDefinitions="Auto, Auto" ColumnSpacing="8" RowSpacing="16">

                            <Picker Grid.Row="0" Grid.Column="0" Title="Seleccionar producto" ItemsSource="{Binding ProductosDisponibles}" SelectedItem="{Binding SelectedProducto}"/>

                            <!-- INPUT ANIMADO: Cantidad -->
                            <Grid Grid.Row="0" Grid.Column="1">
                                <Border x:Name="CantidadBorder" Stroke="#9e9e9e" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" BackgroundColor="Transparent" HeightRequest="44">
                                    <Entry x:Name="CantidadEntry" 
                                           Keyboard="Numeric" 
                                           Text="{Binding CantidadTexto}" 
                                           Focused="Cantidad_Focused"
                                           Unfocused="Cantidad_Unfocused"
                                           Style="{StaticResource EntryStyle}"
                                           BackgroundColor="Transparent"
                                           Margin="8,0"/>
                                </Border>
                                <Label x:Name="CantidadLabel" 
                                       Text="Cant." 
                                       InputTransparent="True" 
                                       BackgroundColor="{StaticResource BackgroundSecondary}" 
                                       TextColor="#e8e8e8" 
                                       HorizontalOptions="Start" 
                                       VerticalOptions="Center" 
                                       Margin="10,0" 
                                       Padding="4,0" />
                            </Grid>

                            <Button Grid.Row="1" Grid.Column="1" Text="Agregar" Command="{Binding AddProductoCommand}" Style="{StaticResource ButtonPrimary}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label Text="Productos añadidos" Style="{StaticResource BodySmall}" FontAttributes="Bold"/>
                <CollectionView ItemsSource="{Binding ProductosEnOrden}" HeightRequest="120">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,4" Padding="8">
                                <Label Grid.Column="0" Text="{Binding Nombre}" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding Cantidad, StringFormat='x{0}'}" VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Text="Eliminar" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveProductoCommand}" CommandParameter="{Binding .}" Style="{StaticResource ButtonOutline}" BackgroundColor="#D32F2F" TextColor="White"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <Button Text="Guardar Entrega" Command="{Binding GuardarEntregaCommand}" Style="{StaticResource ButtonPrimary}" Margin="0,10,0,20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>