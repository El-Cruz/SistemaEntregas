<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="Entregas.MAUI.Views.DetallePedidoPopup">

    <Border BackgroundColor="White" 
            StrokeShape="RoundRectangle 20" 
            Padding="25" 
            WidthRequest="320"
            HorizontalOptions="Center" 
            VerticalOptions="Center">

        <VerticalStackLayout Spacing="10">
            <Label Text="{Binding CodigoEntrega, StringFormat='Pedido: {0}'}" FontSize="18" FontAttributes="Bold" TextColor="#2196F3" HorizontalOptions="Center"/>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,5"/>

            <Label Text="{Binding Destinatario}" FontSize="20" FontAttributes="Bold" TextColor="Black"/>
            <Label Text="{Binding Direccion}" FontSize="14" TextColor="Gray"/>

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Productos}" Spacing="8" Margin="0,15,0,15">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="{Binding Nombre}" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
                            <Label Grid.Column="1" Text="{Binding Cantidad, StringFormat='x{0}'}" FontSize="16" FontAttributes="Bold" TextColor="Black"/>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="Iniciar Entrega" 
                    Clicked="OnCheckClicked"
                    BackgroundColor="Green" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    CornerRadius="10"/>

            <Button Text="Cerrar" 
                    Clicked="OnCerrarClicked"
                    BackgroundColor="Transparent" 
                    TextColor="Gray"
                    Margin="0,5,0,0"/>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>