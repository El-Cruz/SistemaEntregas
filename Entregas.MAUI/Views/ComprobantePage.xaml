<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Entregas.MAUI.Views.ComprobantePage"
             Title="Comprobante de Entrega">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="20">

            <Label Text="Verificación de Entrega" FontSize="20" FontAttributes="Bold"/>

            <Entry x:Name="RepartidorEntry" Placeholder="Nombre del Repartidor (Quien entrega)" />
            <Entry x:Name="ReceptorEntry" Placeholder="Nombre del Receptor (Quien recibe)" />
            <Entry x:Name="ObservacionesEntry" Placeholder="Observaciones adicionales" />

            <Label Text="Firma del Receptor:" FontAttributes="Bold" Margin="0,15,0,0"/>

            <toolkit:DrawingView 
                x:Name="PadFirmaDigital"
                IsMultiLineModeEnabled="True"
                LineColor="Black"
                LineWidth="4"
                HeightRequest="200"
                HorizontalOptions="Fill"
                BackgroundColor="#E0E0E0" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                <Button Grid.Column="0" Text="Limpiar" Clicked="OnLimpiarFirmaClicked" BackgroundColor="Gray" TextColor="White"/>
                <Button Grid.Column="1" Text="Confirmar" Clicked="OnConfirmarEntregaClicked" BackgroundColor="Green" TextColor="White"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>